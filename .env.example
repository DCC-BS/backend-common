# --- Integration tests (tests/integration) -----------------------------------

# LLM API endpoint (OpenAI-compatible, e.g. vLLM).
# Defaults point at the container started by `make llm`.
LLM_PORT=8001
LLM_URL=http://127.0.0.1:${LLM_PORT}/v1

# API key for the LLM endpoint. vLLM ignores it unless started with --api-key.
LLM_API_KEY=dummy-key

# Model name as returned by the endpoint. Passed to vLLM as --served-model-name,
# so the container and the tests always agree on it.
LLM_MODEL=gemma-4-26b

# Per-request timeout in seconds and retry count (LlmConfig).
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# --- vLLM container only (tests/integration/docker-compose.yml) ---------------

# Needed to pull gated weights from the Hugging Face hub.
HUGGING_FACE_HUB_TOKEN=your-hf-token

# Host directory mounted as the container's model cache, so weights survive `make llm-down`.
HUGGING_FACE_CACHE_DIR=/home/youruser/.cache/huggingface

# --- Optional: Logfire tracing for the integration suite ----------------------

# Spans ship when a token is found, either here or in .logfire/logfire_credentials.json
# (written by `logfire auth` + `logfire projects use`). Unset and absent means spans
# stay local and are only printed to the console.
# LOGFIRE_TOKEN=your-logfire-token
